<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="PhotoSorterAvalonia.SettingsWindow"
        Title="Photo Sorter — Settings"
        Width="560" Height="420"
        WindowStartupLocation="CenterOwner"
        CanResize="False">
    <Grid Margin="20" RowDefinitions="Auto,*" RowSpacing="16">
        <TextBlock Grid.Row="0" Text="Library and sort folders"
                   FontSize="18" FontWeight="SemiBold"/>
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="14">
                <TextBlock Text="Library root (photos and sort destinations live under this folder)"
                           FontSize="12" Foreground="#666" TextWrapping="Wrap"/>
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                    <TextBox x:Name="RootPathText" Grid.Column="0"
                             PlaceholderText="Path to your photo library folder"
                             MinHeight="36"/>
                    <Button x:Name="BrowseRootButton" Grid.Column="1"
                            MinWidth="44" Padding="12,8"
                            Click="BrowseRoot_Click"
                            ToolTip.Tip="Browse for folder">
                        <Viewbox Width="20" Height="20">
                            <Path Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  Data="M10,4 L4,4 C2.9,4 2,4.9 2,6 L2,18 C2,19.1 2.9,20 4,20 L20,20 C21.1,20 22,19.1 22,18 L22,8 C22,6.9 21.1,6 20,6 L12,6 L10,4 Z"/>
                        </Viewbox>
                    </Button>
                </Grid>

                <TextBlock Text="Destination subfolders (relative to the library root). You can use nested paths, e.g. round2/picks"
                           FontSize="12" Foreground="#666" TextWrapping="Wrap" Margin="0,8,0,0"/>

                <StackPanel Spacing="6">
                    <TextBlock Text="Good" FontWeight="SemiBold" FontSize="13"/>
                    <TextBox x:Name="GoodFolderText" MinHeight="32"/>
                </StackPanel>
                <StackPanel Spacing="6">
                    <TextBlock Text="Very good" FontWeight="SemiBold" FontSize="13"/>
                    <TextBox x:Name="VeryGoodFolderText" MinHeight="32"/>
                </StackPanel>
                <StackPanel Spacing="6">
                    <TextBlock Text="Sorted out" FontWeight="SemiBold" FontSize="13"/>
                    <TextBox x:Name="SortedOutFolderText" MinHeight="32"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,16,0,0">
                    <Button x:Name="CancelButton" MinWidth="44" Padding="12,8"
                            Click="Cancel_Click"
                            ToolTip.Tip="Cancel">
                        <Viewbox Width="20" Height="20">
                            <Path Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  Data="M19,6.41 L17.59,5 L12,10.59 L6.41,5 L5,6.41 L10.59,12 L5,17.59 L6.41,19 L12,13.41 L17.59,19 L19,17.59 L13.41,12 Z"/>
                        </Viewbox>
                    </Button>
                    <Button x:Name="OkButton" MinWidth="44" Padding="12,8"
                            IsDefault="True"
                            Click="Ok_Click"
                            ToolTip.Tip="Save">
                        <Viewbox Width="20" Height="20">
                            <Path Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  Data="M9,16.17 L4.83,12 L3.41,13.41 L9,19 L21,7 L19.59,5.59 Z"/>
                        </Viewbox>
                    </Button>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
