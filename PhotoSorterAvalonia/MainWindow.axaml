<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
        x:Class="PhotoSorterAvalonia.MainWindow"
        Title="Photo Sorter - Avalonia"
        Width="1400" Height="800">
    
    <Grid RowDefinitions="*,Auto" Margin="20" RowSpacing="10">
        
        <!-- Photo Display Area -->
        <Border Grid.Row="0" Background="#2C2C2C" CornerRadius="10" BorderBrush="#404040" BorderThickness="2">
            <Grid>
                <!-- Image Display with Zoom/Pan -->
                <Image x:Name="CurrentImage" 
                       Stretch="Uniform" 
                       HorizontalAlignment="Center" 
                       VerticalAlignment="Center">
                    <Image.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                            <TranslateTransform X="0" Y="0"/>
                            <RotateTransform Angle="0"/>
                        </TransformGroup>
                    </Image.RenderTransform>
                </Image>
                
                <!-- Zoom controls have been removed for cleaner interface -->
                <!-- Keyboard shortcuts still work: +, -, 0, Q, E -->
                
                <!-- Instructions Overlay -->
                <Border x:Name="InstructionsOverlay" 
                        Background="#80000000" 
                        IsVisible="True"
                        CornerRadius="10"
                        Padding="20">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="500" Spacing="20">
                        <TextBlock Text="📸 Photo Sorter" FontSize="28" FontWeight="Bold" Foreground="White" 
                                   HorizontalAlignment="Center"/>
                        
                        <Border Background="#CC000000" CornerRadius="10" Padding="20">
                            <StackPanel Spacing="15">
                                <TextBlock Text="CONTROLS:" FontSize="18" FontWeight="Bold" Foreground="White"/>
                                
                                <StackPanel Spacing="10">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <Border Background="#333" CornerRadius="5" Padding="10">
                                            <TextBlock Text="←" FontSize="20" FontWeight="Bold" Foreground="White"/>
                                        </Border>
                                        <TextBlock Text="Left click or swipe: Sort out (skip)" 
                                                   FontSize="14" Foreground="White" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <Border Background="#333" CornerRadius="5" Padding="10">
                                            <TextBlock Text="→" FontSize="20" FontWeight="Bold" Foreground="White"/>
                                        </Border>
                                        <TextBlock Text="Right click or swipe: Move to 'good' folder" 
                                                   FontSize="14" Foreground="White" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <Border Background="#333" CornerRadius="5" Padding="10">
                                            <TextBlock Text="↑" FontSize="20" FontWeight="Bold" Foreground="White"/>
                                        </Border>
                                        <TextBlock Text="Up click or swipe: Move to 'very good' folder" 
                                                   FontSize="14" Foreground="White" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>
                                
                                <TextBlock Text="KEYBOARD SHORTCUTS:" FontSize="18" FontWeight="Bold" Foreground="White" 
                                           Margin="0,10,0,0"/>
                                
                                <StackPanel Spacing="5">
                                    <TextBlock Text="• Left Arrow: Previous photo" FontSize="14" Foreground="White"/>
                                    <TextBlock Text="• Right Arrow: Next photo" FontSize="14" Foreground="White"/>
                                    <TextBlock Text="• Up Arrow: Next photo (alternative)" FontSize="14" Foreground="White"/>
                                    <TextBlock Text="• Down Arrow: Previous photo (alternative)" FontSize="14" Foreground="White"/>
                                    <TextBlock Text="• Shift + Left: Sort out" FontSize="14" Foreground="White"/>
                                    <TextBlock Text="• Shift + Right: Move to 'good' folder" FontSize="14" Foreground="White"/>
                                    <TextBlock Text="• Shift + Up: Move to 'very good' folder" FontSize="14" Foreground="White"/>
                                    <TextBlock Text="• Q: Rotate left (counter-clockwise)" FontSize="14" Foreground="White"/>
                                    <TextBlock Text="• E: Rotate right (clockwise)" FontSize="14" Foreground="White"/>
                                    <TextBlock Text="• +: Zoom in" FontSize="14" Foreground="White"/>
                                    <TextBlock Text="• -: Zoom out" FontSize="14" Foreground="White"/>
                                    <TextBlock Text="• 0: Reset zoom" FontSize="14" Foreground="White"/>
                                    <TextBlock Text="• H: Show/hide instructions" FontSize="14" Foreground="White"/>
                                    <TextBlock Text="• Escape: Quit with statistics" FontSize="14" Foreground="White"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        
                        <Button Content="START SORTING" 
                                HorizontalAlignment="Center"
                                Width="200" Height="50" 
                                FontSize="16" FontWeight="Bold"
                                CornerRadius="10"
                                Click="StartSorting_Click"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
        
        <!-- Bottom Panel with Statistics, Progress, and Action Buttons -->
        <Grid Grid.Row="1" ColumnDefinitions="*,*,*,*,Auto,Auto,Auto,Auto" ColumnSpacing="10">
            <!-- Statistics -->
            <Border Grid.Column="0" Background="#3C3C3C" CornerRadius="10" Padding="15">
                <StackPanel>
                    <TextBlock Text="STATISTICS" FontSize="12" FontWeight="Bold" Foreground="#AAAAAA"/>
                    <TextBlock x:Name="StatsText" Text="Loading..." FontSize="14" Foreground="White" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>
            
            <!-- Current File -->
            <Border Grid.Column="1" Background="#3C3C3C" CornerRadius="10" Padding="15">
                <StackPanel>
                    <TextBlock Text="CURRENT FILE" FontSize="12" FontWeight="Bold" Foreground="#AAAAAA"/>
                    <TextBlock x:Name="FileText" Text="No file loaded" FontSize="14" Foreground="White" 
                               Margin="0,5,0,0" TextTrimming="CharacterEllipsis"/>
                </StackPanel>
            </Border>
            
            <!-- Progress -->
            <Border Grid.Column="2" Background="#3C3C3C" CornerRadius="10" Padding="15">
                <StackPanel>
                    <TextBlock Text="PROGRESS" FontSize="12" FontWeight="Bold" Foreground="#AAAAAA"/>
                    <ProgressBar x:Name="ProgressBar" Minimum="0" Maximum="100" Value="0" 
                                 Margin="0,5,0,0" Height="10"/>
                    <TextBlock x:Name="ProgressText" Text="0/0" FontSize="14" Foreground="White" 
                               HorizontalAlignment="Center" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>
            
            <!-- Action Buttons (Focus visuals disabled) -->
            <Button Grid.Column="4" 
                    Content="← SORT OUT" 
                    Background="#666666" Foreground="White"
                    FontSize="16" FontWeight="Bold"
                    Height="60" CornerRadius="10"
                    Click="SortOut_Click"
                    Focusable="False"/>
            
            <Button Grid.Column="5" 
                    Content="GOOD →" 
                    Background="#2E7D32" Foreground="White"
                    FontSize="16" FontWeight="Bold"
                    Height="60" CornerRadius="10"
                    Click="Good_Click"
                    Focusable="False"/>
            
            <Button Grid.Column="6" 
                    Content="↑ VERY GOOD" 
                    Background="#1565C0" Foreground="White"
                    FontSize="16" FontWeight="Bold"
                    Height="60" CornerRadius="10"
                    Click="VeryGood_Click"
                    Focusable="False"/>
            
            <Button Grid.Column="7" 
                    Content="QUIT" 
                    Background="#C62828" Foreground="White"
                    FontSize="16" FontWeight="Bold"
                    Height="60" CornerRadius="10"
                    Click="Quit_Click"
                    Focusable="False"/>
        </Grid>
    </Grid>
    
</Window>
