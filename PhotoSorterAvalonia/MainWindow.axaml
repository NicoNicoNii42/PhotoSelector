<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
        x:Class="PhotoSorterAvalonia.MainWindow"
        Title="Photo Sorter - Avalonia"
        Width="1400" Height="800">
    
    <Grid RowDefinitions="*,Auto" Margin="20" RowSpacing="10">
        
        <!-- Photo Display Area with Viewbox for responsive sizing (pointer handlers on this border cover letterboxing too) -->
        <Border x:Name="PhotoStageBorder" Grid.Row="0" Background="#2C2C2C" CornerRadius="10" BorderBrush="#404040" BorderThickness="2">
            <Viewbox x:Name="ImageContainer" Stretch="Uniform">
                <Grid Background="Transparent">
                    <!-- Image Display with Zoom/Pan -->
                    <Image x:Name="CurrentImage" 
                           Stretch="None" 
                           HorizontalAlignment="Center" 
                           VerticalAlignment="Center"
                           RenderTransformOrigin="0.5,0.5">
                        <Image.RenderTransform>
                            <!-- Avalonia multiplies left-to-right: M = T * S * R → applies R, then S, then T to points. -->
                            <TransformGroup>
                                <TranslateTransform X="0" Y="0"/>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                                <RotateTransform Angle="0"/>
                            </TransformGroup>
                        </Image.RenderTransform>
                    </Image>
                    
                    <!-- Zoom controls have been removed for cleaner interface -->
                    <!-- Keyboard shortcuts still work: +, -, 0, Q, E -->
                    
                    <!-- Instructions Overlay -->
                    <Border x:Name="InstructionsOverlay" 
                            Background="#80000000" 
                            IsVisible="True"
                            CornerRadius="10"
                            Padding="20">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="500" Spacing="20">
                        <TextBlock Text="📸 Photo Sorter" FontSize="28" FontWeight="Bold" Foreground="White" 
                                   HorizontalAlignment="Center"/>
                        
                        <Border Background="#CC000000" CornerRadius="10" Padding="20">
                            <StackPanel Spacing="15">
                                <TextBlock Text="CONTROLS:" FontSize="18" FontWeight="Bold" Foreground="White"/>
                                
                                <StackPanel Spacing="10">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <Border Background="#333" CornerRadius="5" Padding="10">
                                            <TextBlock Text="←" FontSize="20" FontWeight="Bold" Foreground="White"/>
                                        </Border>
                                        <TextBlock Text="Shift + Left: Sort out" 
                                                   FontSize="14" Foreground="White" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <Border Background="#333" CornerRadius="5" Padding="10">
                                            <TextBlock Text="→" FontSize="20" FontWeight="Bold" Foreground="White"/>
                                        </Border>
                                        <TextBlock Text="Shift + Right: Move to 'good' folder" 
                                                   FontSize="14" Foreground="White" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <Border Background="#333" CornerRadius="5" Padding="10">
                                            <TextBlock Text="↑" FontSize="20" FontWeight="Bold" Foreground="White"/>
                                        </Border>
                                        <TextBlock Text="Shift + Up: Move to 'very good' folder" 
                                                   FontSize="14" Foreground="White" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>
                                
                                <TextBlock Text="KEYBOARD SHORTCUTS:" FontSize="18" FontWeight="Bold" Foreground="White" 
                                           Margin="0,10,0,0"/>
                                
                                <StackPanel Spacing="5">
                                    <TextBlock Text="• Left Arrow: Previous photo" FontSize="14" Foreground="White"/>
                                    <TextBlock Text="• Right Arrow: Next photo" FontSize="14" Foreground="White"/>
                                    <TextBlock Text="• Up Arrow: Next photo (alternative)" FontSize="14" Foreground="White"/>
                                    <TextBlock Text="• Down Arrow: Previous photo (alternative)" FontSize="14" Foreground="White"/>
                                    <TextBlock Text="• Shift + Left: Sort out" FontSize="14" Foreground="White"/>
                                    <TextBlock Text="• Shift + Right: Move to 'good' folder" FontSize="14" Foreground="White"/>
                                    <TextBlock Text="• Shift + Up: Move to 'very good' folder" FontSize="14" Foreground="White"/>
                                    <TextBlock Text="• Q: Rotate left (counter-clockwise)" FontSize="14" Foreground="White"/>
                                    <TextBlock Text="• E: Rotate right (clockwise)" FontSize="14" Foreground="White"/>
                                    <TextBlock Text="• W: Zoom in" FontSize="14" Foreground="White"/>
                                    <TextBlock Text="• S: Zoom out" FontSize="14" Foreground="White"/>
                                    <TextBlock Text="• 0: Reset zoom" FontSize="14" Foreground="White"/>
                                    <TextBlock Text="• Drag on preview: Pan (does not sort)" FontSize="14" Foreground="White"/>
                                    <TextBlock Text="• Trackpad scroll on preview: Zoom" FontSize="14" Foreground="White"/>
                                    <TextBlock Text="• H: Show/hide instructions" FontSize="14" Foreground="White"/>
                                    <TextBlock Text="• Escape: Quit application" FontSize="14" Foreground="White"/>
                                    <TextBlock Text="• SETTINGS: Choose library root and rename sort subfolders" 
                                               FontSize="14" Foreground="White" TextWrapping="Wrap"/>
                                    <TextBlock Text="• Folder (bottom bar): Switch between the library root and Good / Very good / Sorted out under that root" 
                                               FontSize="14" Foreground="White" TextWrapping="Wrap"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        
                        <Button HorizontalAlignment="Center"
                                Width="56" Height="56"
                                CornerRadius="10"
                                Background="#F5F5F5" Foreground="#212121"
                                Click="StartSorting_Click"
                                ToolTip.Tip="Start sorting">
                            <Viewbox Width="28" Height="28">
                                <Path Fill="#212121"
                                      Data="M8,5 L8,19 L19,12 Z"/>
                            </Viewbox>
                        </Button>
                    </StackPanel>
                </Border>
                </Grid>
            </Viewbox>
        </Border>
        
        <!-- Bottom: one connected bar (no flex gap — was an empty * column before the toolbar) -->
        <Border Grid.Row="1"
                Background="#383838"
                CornerRadius="10"
                BorderBrush="#555555"
                BorderThickness="1"
                ClipToBounds="True"
                Padding="0">
            <Grid ColumnDefinitions="*,*,*,*,Auto" ColumnSpacing="0">
                <!-- Statistics -->
                <Border Grid.Column="0" Padding="14" BorderBrush="#4A4A4A" BorderThickness="0,0,1,0">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="STATISTICS" FontSize="12" FontWeight="Bold" Foreground="#AAAAAA"/>
                        <TextBlock x:Name="StatsText" Text="Loading..." FontSize="14" Foreground="White" Margin="0,5,0,0"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
                
                <!-- Current (working) folder -->
                <Border Grid.Column="1" Padding="14" BorderBrush="#4A4A4A" BorderThickness="0,0,1,0">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="CURRENT FOLDER" FontSize="12" FontWeight="Bold" Foreground="#AAAAAA"/>
                        <TextBlock x:Name="WorkingFolderText" Text="—" FontSize="14" Foreground="White" Margin="0,5,0,0"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
                
                <!-- Current File -->
                <Border Grid.Column="2" Padding="14" BorderBrush="#4A4A4A" BorderThickness="0,0,1,0">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="CURRENT FILE" FontSize="12" FontWeight="Bold" Foreground="#AAAAAA"/>
                        <TextBlock x:Name="FileText" Text="No file loaded" FontSize="14" Foreground="White" 
                                   Margin="0,5,0,0" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Border>
                
                <!-- Progress (clip: Fluent progress track can paint wider than the cell) -->
                <Border Grid.Column="3" Padding="14" BorderBrush="#4A4A4A" BorderThickness="0,0,1,0" ClipToBounds="True">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="PROGRESS" FontSize="12" FontWeight="Bold" Foreground="#AAAAAA"/>
                        <ProgressBar x:Name="ProgressBar" Minimum="0" Maximum="100" Value="0" 
                                     Margin="0,5,0,0" Height="10" HorizontalAlignment="Stretch" MinWidth="0"/>
                        <TextBlock x:Name="ProgressText" Text="0/0" FontSize="14" Foreground="White" 
                                   HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
                
                <!-- Actions: slightly darker band, flush with progress -->
                <Border Grid.Column="4" Background="#2F2F2F" Padding="12,10">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="10">
                        <Button Background="#666666" Foreground="White"
                                Height="52" MinWidth="52" Padding="12,0" CornerRadius="8"
                                Click="SortOut_Click"
                                Focusable="False"
                                ToolTip.Tip="Sort out (Shift+←)">
                            <Viewbox Width="24" Height="24">
                                <Path Fill="White"
                                      Data="M3,6 L21,6 L21,8 L3,8 Z M5,9 L19,9 L18,23 L6,23 Z M10,11 L10,21 L12,21 L12,11 Z M14,11 L14,21 L16,21 L16,11 Z M9,3 L15,3 L15,5 L9,5 Z"/>
                            </Viewbox>
                        </Button>
                        <Button Background="#2E7D32" Foreground="White"
                                Height="52" MinWidth="52" Padding="12,0" CornerRadius="8"
                                Click="Good_Click"
                                Focusable="False"
                                ToolTip.Tip="Good (Shift+→)">
                            <Viewbox Width="24" Height="24">
                                <Path Fill="White"
                                      Data="M9,16.17 L4.83,12 L3.41,13.41 L9,19 L21,7 L19.59,5.59 Z"/>
                            </Viewbox>
                        </Button>
                        <Button Background="#1565C0" Foreground="White"
                                Height="52" MinWidth="52" Padding="12,0" CornerRadius="8"
                                Click="VeryGood_Click"
                                Focusable="False"
                                ToolTip.Tip="Very good (Shift+↑)">
                            <Viewbox Width="24" Height="24">
                                <Path Fill="White"
                                      Data="M12,17.27 L18.18,21 L16.54,13.97 L22,9.24 L14.81,8.63 L12,2 L9.19,8.63 L2,9.24 L7.46,13.97 L5.82,21 Z"/>
                            </Viewbox>
                        </Button>
                        <Border Width="1" Height="34" Background="#606060" Margin="2,0"/>
                        <Button Background="#455A64" Foreground="White"
                                Height="52" MinWidth="52" Padding="12,0" CornerRadius="8"
                                Click="Settings_Click"
                                Focusable="False"
                                ToolTip.Tip="Settings">
                            <Viewbox Width="24" Height="24">
                                <!-- Bootstrap Icons gear-fill (viewBox 0 0 16 16) -->
                                <Path Fill="White"
                                      Data="M9.405 1.05c-.413-1.4-2.397-1.4-2.81 0l-.1.34a1.464 1.464 0 0 1-2.105.872l-.31-.17c-1.283-.698-2.686.705-1.987 1.987l.169.311c.446.82.023 1.841-.872 2.105l-.34.1c-1.4.413-1.4 2.397 0 2.81l.34.1a1.464 1.464 0 0 1 .872 2.105l-.17.31c-.698 1.283.705 2.686 1.987 1.987l.311-.169a1.464 1.464 0 0 1 2.105.872l.1.34c.413 1.4 2.397 1.4 2.81 0l.1-.34a1.464 1.464 0 0 1 2.105-.872l.31.17c1.283.698 2.686-.705 1.987-1.987l-.169-.311a1.464 1.464 0 0 1 .872-2.105l.34-.1c1.4-.413 1.4-2.397 0-2.81l-.34-.1a1.464 1.464 0 0 1-.872-2.105l.17-.31c.698-1.283-.705-2.686-1.987-1.987l-.311.169a1.464 1.464 0 0 1-2.105-.872zM8 10.93a2.929 2.929 0 1 1 0-5.86 2.929 2.929 0 0 1 0 5.858z"/>
                            </Viewbox>
                        </Button>
                        <ComboBox x:Name="WorkingFolderCombo"
                                  MinWidth="150" MaxWidth="220"
                                  Height="52"
                                  FontSize="13" FontWeight="Bold"
                                  Foreground="White"
                                  Background="#37474F"
                                  BorderBrush="#546E7A"
                                  CornerRadius="8"
                                  VerticalContentAlignment="Center"
                                  Padding="10,0"
                                  PlaceholderText="Folder"
                                  SelectionChanged="WorkingFolderCombo_SelectionChanged"
                                  Focusable="False"/>
                        <Button Background="#C62828" Foreground="White"
                                Height="52" MinWidth="52" Padding="12,0" CornerRadius="8"
                                Click="Quit_Click"
                                Focusable="False"
                                ToolTip.Tip="Quit (Esc)">
                            <Viewbox Width="24" Height="24">
                                <Path Fill="White"
                                      Data="M13,3 L11,3 L11,13 L13,13 Z M16.56,5.44 L15.11,6.89 C16.84,7.94 18,9.83 18,12 C18,15.31 15.31,18 12,18 C8.69,18 6,15.31 6,12 C6,9.83 7.16,7.94 8.89,6.89 L7.44,5.44 C5.47,6.85 4,9.32 4,12 C4,16.42 7.58,20 12,20 C16.42,20 20,16.42 20,12 C20,9.32 18.53,6.85 16.56,5.44 Z"/>
                            </Viewbox>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
    
</Window>
